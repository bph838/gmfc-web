[
  {
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug Prerender Script",
        "skipFiles": ["<node_internals>/**"],
        "program": "${workspaceFolder}/prerender.js",
        "console": "integratedTerminal"
      }
    ]
  },
  {
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug Prerender Script",
        "skipFiles": ["<node_internals>/**"],
        "program": "${workspaceFolder}/lapmonitor.js",
        "console": "integratedTerminal"
      }
    ]
  },
  {
    "version": "0.2.0",
    "configurations": [
      {
        "type": "chrome",
        "request": "launch",
        "name": "Debug GMFC Site",
        "url": "http://localhost:8080",
        "webRoot": "${workspaceFolder}",
        "sourceMaps": true,
        "sourceMapPathOverrides": {
          "webpack:///./src/*": "${webRoot}/src/*",
          "webpack:///src/*": "${webRoot}/src/*",
          "webpack:///*": "${webRoot}/*",
          "webpack://[name]/./src/*": "${webRoot}/src/*"
        }
      }
    ]
  },
  {
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug Webpack",
        "runtimeExecutable": "node",
        "runtimeArgs": [
          "--inspect-brk",
          "./node_modules/webpack/bin/webpack.js",
          "--mode",
          "development"
        ],
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**"]
      }
    ]
  }
]
